# TechPulse Environment Variables
# Copy this file to .env and fill in your values

# Semantic Scholar API (optional - free tier works without key, but key increases rate limits)
SEMANTIC_SCHOLAR_API_KEY=

# KIPRIS API (Korean patents) — free key from https://www.data.go.kr
KIPRIS_API_KEY=

# Lens.org (worldwide patents, easiest) — free account at https://www.lens.org → Profile → API Access
LENS_API_KEY=

# EPO OPS (worldwide patents incl. US/KR) — free account at https://developers.epo.org/
EPO_OPS_KEY=
EPO_OPS_SECRET=

# OpenAlex polite pool (recommended - add your email for better rate limits)
OPENALEX_EMAIL=your@email.com

# Database path
DB_PATH=data/techpulse.db

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
